{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bizu Sidebar",
  "version": "0.1.0",
  "identifier": "com.junior.bizu",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "beforeBuildCommand": "corepack pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Bizu Sidebar",
        "width": 455,
        "height": 920,
        "minWidth": 455,
        "maxWidth": 455,
        "minHeight": 420,
        "visible": true,
        "resizable": true,
        "maximizable": false,
        "minimizable": true,
        "closable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
